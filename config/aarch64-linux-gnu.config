CT_CONFIG_VERSION="4"
CT_OBSOLETE=y
CT_EXPERIMENTAL=y
CT_ALLOW_BUILD_AS_ROOT=y
CT_ALLOW_BUILD_AS_ROOT_SURE=y
CT_LOCAL_TARBALLS_DIR="/tmp/tarballs"
CT_SAVE_TARBALLS=y
CT_ARCH_ARM=y
CT_OMIT_TARGET_VENDOR=y
CT_ARCH_64=y
CT_KERNEL_LINUX=y
CT_LINUX_V_3_10=y
CT_BINUTILS_V_2_46=y
CT_GLIBC_V_2_26=y
CT_GCC_V_16=y
CT_CC_GCC_LIBGOMP=y
CT_CC_GCC_LIBSANITIZER=y
CT_CC_LANG_CXX=y
CT_DEBUG_GDB=y
